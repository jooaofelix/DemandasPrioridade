# Valores fictícios usados apenas durante `npm test`, para que a inicialização
# do Firebase SDK não falhe ao importar módulos que dependem dele. Nenhuma
# chamada de rede real é feita pelos testes unitários/componentes.
VITE_FIREBASE_API_KEY=test-api-key
VITE_FIREBASE_AUTH_DOMAIN=demo-agora.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=demo-agora
VITE_FIREBASE_STORAGE_BUCKET=demo-agora.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=000000000000
VITE_FIREBASE_APP_ID=1:000000000000:web:0000000000000000000000
