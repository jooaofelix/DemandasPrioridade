# Copie este arquivo para ".env.local" e preencha com os dados do seu projeto Firebase.
# Console: https://console.firebase.google.com -> Configurações do projeto -> Seus apps -> Web app
# Nenhuma dessas chaves é secreta no sentido de back-end: elas identificam o projeto Firebase
# no cliente. A segurança real vem das Firestore Security Rules (ver firestore.rules) e do
# App Check. Ainda assim, não commite o arquivo .env.local.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opcional: chave pública do reCAPTCHA v3 para o Firebase App Check.
# Deixe em branco para desativar o App Check em desenvolvimento.
VITE_FIREBASE_APPCHECK_SITE_KEY=
